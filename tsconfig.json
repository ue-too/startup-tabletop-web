{
    "compilerOptions": {
        "baseUrl": ".",
        "declaration": true,
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "outDir": "dist",
        "paths": {
            "@/*": ["./src/*"]
        },
        "resolveJsonModule": true,
        "strict": true,
        "target": "ES2020",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowImportingTsExtensions": false,
        "types": ["bun"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
